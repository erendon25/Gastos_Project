rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'erickrendon18@gmail.com';
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      
      // Permitimos la creación si no envían campos sensibles o son false
      allow create: if request.auth != null && (request.auth.uid == userId || isSuperAdmin())
                   && (!request.resource.data.keys().hasAny(['isPro', 'proUntil', 'isPremium']) 
                       || (request.resource.data.get('isPro', false) == false 
                           && request.resource.data.get('isPremium', false) == false));
      
      // Permitimos la actualización si no cambian campos de suscripción
      allow update: if request.auth != null && (request.auth.uid == userId || isSuperAdmin())
                   && (isSuperAdmin() || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPro', 'proUntil', 'isPremium']));
      
      match /{collectionName}/{docId} {
        // Colecciones de datos de usuario (gastos, ingresos, etc) son editables por el dueño
        // pero la subcolección 'premium' debe ser protegida
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin())
                         && (collectionName != 'premium' || isSuperAdmin());
      }

      // Regla específica para la subcolección de estatus premium
      match /premium/status {
        allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
        allow write: if isSuperAdmin(); // Solo admin (o functions que usan Admin SDK) pueden escribir aquí
      }
    }
    
    // Reglas transversales para Superadmin (estadísticas globales)
    match /{path=**}/gastos/{docId} {
      allow read: if isSuperAdmin();
    }
    match /{path=**}/ingresos/{docId} {
      allow read: if isSuperAdmin();
    }
    match /{path=**}/prestamos/{docId} {
      allow read: if isSuperAdmin();
    }
    match /{path=**}/gastos_recurrentes/{docId} {
      allow read: if isSuperAdmin();
    }
    match /{path=**}/ingresos_recurrentes/{docId} {
      allow read: if isSuperAdmin();
    }
    
    match /referrals/{referralId} {
      allow read: if request.auth != null && (resource == null || resource.data.referrerId == request.auth.uid || resource.data.referredId == request.auth.uid || isSuperAdmin());
      allow create: if request.auth != null && (request.resource.data.referredId == request.auth.uid || isSuperAdmin());
      allow update: if request.auth != null && (resource.data.referredId == request.auth.uid || resource.data.referrerId == request.auth.uid || isSuperAdmin());
    }
  }
}
